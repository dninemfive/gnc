@page "/naibbe"
@using gnc.gui.Components

<title>Naibbe Cipher</title>

<InputText @bind-Value="plaintext"/>
<button class="btn btn-primary" @onclick="DoStuff">&#xff401;&#xff410;&#xff400;&#xff408;&#xff408;&#xff407;</button>

<output style="box-sizing: border-box">
    @foreach (HistoryWord word in words)
    {
        <d9.gnc.gui.Components.WordView Word="word"/>
    }
</output>

@code {

    private string plaintext = "";
    private List<HistoryWord> words = [];

    private async Task DoStuff() {        
        words.Clear();
        NaibbeCipher cipher = await NaibbeCipher.MakeDefault(@"C:\Users\dninemfive\Documents\workspaces\misc\Naibbe\data");

        foreach (RespacedWord respacedWord in cipher.Prepare(plaintext))
        {
            EncipheredWord encipheredWord = cipher.Encipher(respacedWord);

        }
    }
}
